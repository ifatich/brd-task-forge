// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Users (Fase 2: Auth) ──
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
}

// ── Projects ──
model Project {
  id            String   @id @default(cuid())
  userId        String?
  title         String
  description   String   @default("")
  status        String   @default("draft") // active | completed | draft
  fileUrl       String   @default("")
  drafts        String   @default("") // JSON string
  reasoning     String   @default("")
  erdMermaid    String   @default("")
  flowMermaid   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tasks         Task[]
  moduleDiagrams ModuleDiagram[]
  logs          ProjectLog[]
  user          User?    @relation(fields: [userId], references: [id])
}

// ── Tasks (module-level) ──
model Task {
  id              String    @id @default(cuid())
  projectId       String
  title           String
  description     String    @default("")
  goals           String    @default("") // JSON array
  definitionOfDone String   @default("")
  status          String    @default("todo") // todo | in-progress | done
  priority        String    @default("medium") // low | medium | high
  assignee        String?   // legacy name field
  assigneeId      String?
  order           Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subTasks        SubTask[]
  assigneeMember  TeamMember? @relation(fields: [assigneeId], references: [id])
}

// ── Sub-tasks (screen-level) ──
model SubTask {
  id              String   @id @default(cuid())
  taskId          String
  title           String
  description     String   @default("")
  goals           String   @default("") // JSON array
  definitionOfDone String  @default("")
  elements        String   @default("") // JSON array — Elemen UI
  done            Boolean  @default(false)
  order           Int      @default(0)
  assignee        String?
  assigneeId      String?
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assigneeMember  TeamMember? @relation("SubTaskAssignee", fields: [assigneeId], references: [id])
}

// ── Module Diagrams ──
model ModuleDiagram {
  id           String   @id @default(cuid())
  projectId    String
  mermaidSyntax String  @default("")
  modules      String   @default("") // JSON
  subDiagrams  String   @default("") // JSON
  nodeDetails  String   @default("") // JSON
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ── Project Logs (riwayat aktivitas) ──
model ProjectLog {
  id        String   @id @default(cuid())
  projectId String
  action    String   // created | task_added | task_completed | status_changed | etc
  detail    String   @default("") // human-readable description
  userId    String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ── Team Members ──
model TeamMember {
  id        String   @id
  name      String
  email     String   @default("")
  avatar    String   @default("")
  role      String   @default("")
  createdAt DateTime @default(now())
  tasks     Task[]
  subTasks  SubTask[] @relation("SubTaskAssignee")
}

// ── Team Invitations ──
model Invitation {
  id        String   @id @default(cuid())
  email     String
  projectId String?
  role      String   @default("member")
  token     String   @unique
  status    String   @default("pending") // pending | accepted | declined | expired
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── API Keys for AI Providers ──
model ApiKey {
  id        String   @id @default(cuid())
  provider  String   // openai | anthropic | gemini | huggingface | custom
  label     String   @default("")
  keyValue  String
  baseUrl   String   @default("")
  model     String   @default("") // model name, e.g. gemini-3.1-pro-preview
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── System Configuration (key-value) ──
model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

// ── Knowledge Files ──
model KnowledgeFile {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("Instruksi") // Prompt | Skill | Instruksi
  content   String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
